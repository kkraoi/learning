{
	"YARD Method Documentation": {
		"prefix": "myyard",
		"body": [
			"# ${1:Description of the method}",
			"#",
			"# @param ${2:param_name} [${3:Type}] ${4:description}",
			"# @return [${5:Type}] ${6:description}",
			"# @raise [${7:ErrorClass}] ${8:description}",
			"# @example",
			"#   ${9:example_code}",
			"# @note ${10:Note here}",
			"# @since ${11:1.0.0}"
		],
		"description": "YARD documentation for methods"
	},
	"YARD Class Documentation": {
		"prefix": "myyardclass",
		"body": [
			"# ${1:Class description}",
			"#",
			"# @!attribute [r] ${2:attr_name}",
			"#   @return [${3:Type}] ${4:description}",
			"#",
			"# @example Create instance",
			"#   ${5:instance} = ${TM_FILENAME_BASE/(?:^|_)([a-zA-Z0-9])/\\u$1/g}.new",
			"#",
			"# @see http://example.com Related Documentation"
		],
		"description": "YARD documentation for classes"
	},
	"RSpec Example": {
		"prefix": "myrspec",
		"body": [
			"RSpec.describe ${1:Class} do",
			"  let(:${2:instance}) { described_class.new(${3:args}) }",
			"",
			"  describe '##{4:method}' do",
			"    subject { ${2:instance}.${4:method} }",
			"",
			"    context 'when ${5:condition}' do",
			"      it '${6:expectation}' do",
			"        expect(subject).to ${7:eq(true)}",
			"      end",
			"    end",
			"  end",
			"end"
		],
		"description": "RSpec test structure"
	},
	"Type Signature": {
		"prefix": "mytype",
		"body": [
			"# @type ${1:type_name} { ${2:Type} }",
			"# @type! ${3:method_name} -> { params(${4:arg}: ${5:Type}).returns(${6:ReturnType}) }"
		],
		"description": "Type annotations"
	},
	"Exception Handling": {
		"prefix": "myerror",
		"body": [
			"begin",
			"  ${1:risky_code}",
			"rescue ${2:ErrorClass} => e",
			"  ${3:logger.error(\"Failed: #{e.message}\")}",
			"  ${4:fallback_action}",
			"ensure",
			"  ${5:cleanup}",
			"end"
		],
		"description": "Exception handling block"
	},
	"Strong Parameters (Basic)": {
		"prefix": "mystpara",
		"body": [
			"def ${1:model}_params",
			"  params.require(:${1:model}).permit(",
			"    :${2:attribute},",
			"    :${3:attribute}",
			"  )",
			"end"
		],
		"description": "Basic strong parameters for single model"
	},
	"before_action (Basic)": {
		"prefix": "mybefore_action",
		"body": [
			"before_action :${1:method_name}, only: [:${2:action}]"
		],
		"description": "Basic before_action with action limitation"
	},
	"redirect_to (Flash)": {
		"prefix": "myredirect_to",
		"body": "redirect_to ${1|root_path,user_path(current_user),request.referer,fallback_location: root_path|}, ${2|notice,alert|}: '${3:Message}'",
		"description": "Redirect with flash message"
	},
		"has_many (Basic)": {
		"prefix": "myhas_many",
		"body": "has_many :${1:モデル名}, dependent: :${2|destroy,nullify,delete_all,restrict_with_error|}",
		"description": "has_many association with dependent options"
	},
	"has_many (Conditional)": {
		"prefix": "myhas_many_if",
		"body": "has_many :${1:モデル名}, -> { ${2|where(active: true),order(:created_at),limit(10)|} }, dependent: :destroy",
		"description": "has_many with scope"
	},
	"has_many through": {
		"prefix": "myhas_many_through",
		"body": "has_many :${1:モデル名}, through: :${2:中間テーブル名}",
		"description": "has_many through association"
	},
	"Polymorphic Association": {
		"prefix": "mypoly",
		"body": [
			"belongs_to :${1:ポリモーフィック名}, polymorphic: true",
			"has_many :${2:モデル名}, as: :${1:ポリモーフィック名}, dependent: :destroy"
		],
		"description": "Polymorphic association pair"
},
	"belongs_to (Required)": {
		"prefix": "mybelongs_to",
		"body": "belongs_to :${1:モデル名}, optional: ${2|false,true|}",
		"description": "belongs_to with optional flag"
	},
		"belongs_to (FK Custom)": {
		"prefix": "mybelongs_to_fk",
		"body": "belongs_to :${1:モデル名}, foreign_key: :${2:カラム名}, class_name: '${3:クラス名}'",
		"description": "belongs_to with custom FK"
	},
	"Validation (Presence)": {
		"prefix": "myvalid",
		"body": "validates :${1:attribute}, presence: true",
		"description": "Basic presence validation"
	},
	"Validation (Common Combo)": {
		"prefix": "myvalid_combo",
		"body": "validates :${1:attribute}, presence: true, ${2|length: { minimum: 6 },format: { with: /\\A[\\w+\\-.]+@[a-z\\d\\-]+\\.[a-z]+\\z/i },uniqueness: true|}",
		"description": "Common validation combinations"
	},
	"Validation (Conditional)": {
		"prefix": "myvalid_if",
		"body": "validates :${1:attribute}, presence: true, if: -> { ${2:condition} }",
		"description": "Conditional validation"
	},
	"Validation (Numericality)": {
		"prefix": "myvalid_num",
		"body": "validates :${1:attribute}, numericality: { ${2|greater_than: 0,less_than: 100,only_integer: true|} }",
		"description": "Numericality validation"
	},
		"Routing (Root)": {
		"prefix": "myroot",
		"body": "root to: '${1:controller}#${2|index,show,new|}'",
		"description": "Root route definition"
	},
	"Routing (GET)": {
		"prefix": "myget",
		"body": [
			"get '${1:path}', to: '${2:controller}#${3|index,show,new,create,edit,update,destroy|}', as: :${4:custom_name}",
		],
		"description": "GET route with two syntax options"
	},
	"Routing (GET_ARROW)": {
		"prefix": "myget_arrow",
		"body": [
			"get '${1:path}' => '${2:controller}#${3|index,show,new,create,edit,update,destroy|}'"
		],
		"description": "GET route with two syntax options"
	},
	"Routing (Resources Basic)": {
		"prefix": "myresources",
		"body": "resources :${1:model}, only: [${2::index,:show,:new,:create,:edit,:update,:destroy}]",
		"description": "Basic resources routing"
	},
	"Routing (Resources Advanced)": {
		"prefix": "myresources_adv",
		"body": [
			"resources :${1:model} do",
			"  collection do",
			"    get :${2:search}",
			"  end",
			"  member do",
			"    post :${3:approve}",
			"  end",
			"end"
		],
		"description": "Advanced resources routing with collection/member"
	},
	"Routing (Namespaced)": {
		"prefix": "mynamespace",
		"body": [
			"namespace :${1:admin} do",
			"  resources :${2:model}",
			"  root to: '${3:dashboard}#index'",
			"end"
		],
		"description": "Namespaced routing"
	}
}